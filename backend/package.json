{
  "name": "ai-website-builder",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc && rm -rf dist/templates && cp -r src/templates dist/templates && node -e \"const fs=require('fs');const p=require('path');for(const d of ['frontend','backend']){const f=p.join('dist/templates',d);if(!fs.existsSync(f)){console.error('postbuild: missing '+f);process.exit(1)}}console.log('postbuild: dist/templates OK')\"",
    "start": "npm run build && node dist/index.js",
    "test:pipeline": "node scripts/pipeline-test.js",
    "test:pipeline:fast": "node scripts/pipeline-test.js --skip server,docker,ws,orchestration",
    "test:tsc": "npx tsc --noEmit"
  },
  "dependencies": {
    "@fastify/http-proxy": "^11.4.4",
    "@fastify/static": "^9.1.3",
    "axios": "^1.15.2",
    "dotenv": "^17.4.2",
    "express": "^4.19.0",
    "fastify": "^5.8.5",
    "ioredis": "^5.10.1",
    "openai": "^6.34.0",
    "pg": "^8.20.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
